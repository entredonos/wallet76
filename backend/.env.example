# ============================================================
# Wallet76 backend — TEMPLATE de variáveis de ambiente
# ============================================================
# Copiar para `backend/.env` e preencher com valores REAIS.
# O ficheiro real (.env) está no .gitignore e NUNCA deve ser comitado.
#
# ⚠️  BROKER_ENCRYPTION_KEY: é a chave-mestra que cifra as credenciais de
#     corretora de TODOS os utilizadores. Se a perderes/mudares, todas as
#     ligações de corretora já guardadas ficam permanentemente ilegíveis.
#     Guarda-a num gestor de segredos, não aqui. Gerar uma nova (só para
#     um deploy novo, do zero) com:
#         python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ------------------------------------------------------------

# Base de dados
MONGO_URL=mongodb+srv://<utilizador>:<password>@<cluster>.mongodb.net/
DB_NAME=Wallet76

# Autenticação — gerar 256 bits aleatórios:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=<segredo_aleatorio_256_bits>

# Email (Resend)
RESEND_API_KEY=re_<...>
EMAIL_FROM=Wallet76 <no-reply@teu-dominio.com>

# Frontend
FRONTEND_URL=https://wallet76.com

# Stripe
STRIPE_SECRET_KEY=sk_live_<...>
STRIPE_PRICE_MONTHLY=price_<...>
STRIPE_PRICE_YEARLY=price_<...>
STRIPE_WEBHOOK_SECRET=whsec_<...>

# Cifra de credenciais de corretora (ver aviso acima)
BROKER_ENCRYPTION_KEY=<chave_fernet_base64>
