# ============================================================
# Wallet76 — .gitignore (criado 16 jul 2026)
# ============================================================
# CRÍTICO: nunca comitar segredos. O backend/.env tinha a chave-mestra
# de cifra das credenciais de corretora, MONGO_URL com password, JWT,
# Stripe e Resend em texto simples. Ver backend/.env.example para o
# template sem segredos.
# ------------------------------------------------------------

# Segredos / ambiente
.env
.env.*
!.env.example
*.env
backend/.env
frontend/.env
frontend/.env.*
!frontend/.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
backend/venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.eslintcache

# Artefactos de build nativos (grandes — não pertencem ao git)
*.exe
*.exe.blockmap
*.apk
*.aab
frontend/android/app/build/
frontend/android/.gradle/
frontend/ios/App/build/

# IDE / SO
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs / temporários
*.log
tmp/
.tmp/
_backup_*/
_backup_*/
